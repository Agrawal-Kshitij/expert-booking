{
  "name": "expert-session-booking-backend",
  "version": "1.0.0",
  "description": "Real-time expert session booking backend with Node.js, Express, MongoDB, and Socket.io",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "seed": "node backend/src/scripts/seedExperts.js",
    "client": "cd frontend && npm run dev",
    "install-client": "cd frontend && npm install",
    "dev-all": "concurrently \"npm run dev\" \"npm run client\""
  },
  "keywords": [
    "expert",
    "booking",
    "socket.io",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.6.1",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^2.0.22"
  }
}
